import java.io.*;

public class StudentFile {

    public static void main(String[] args) {

        FileWriter fw = null;
        BufferedReader br = null;

        try {
            // Writing to file
            fw = new FileWriter("students.txt");
            fw.write("101 Yashvi 85\n");
            fw.write("102 Riya 78\n");
            fw.write("103 Aarav 92\n");

            System.out.println("Student records written to file.\n");

            fw.close(); // close after writing

            // Reading from file
            br = new BufferedReader(new FileReader("students.txt"));
            String line;

            System.out.println("Reading student records:\n");

            while ((line = br.readLine()) != null) {
                System.out.println(line);
            }

        } catch (IOException e) {
            System.out.println("Error: " + e.getMessage());
        } finally {
            try {
                if (fw != null)
                    fw.close();
                if (br != null)
                    br.close();
            } catch (IOException e) {
                System.out.println("Error closing file.");
            }
        }
    }
}
